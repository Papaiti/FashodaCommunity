{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student in the community program",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the student" },
        "studentId": { "type": "string", "description": "Unique student identifier" },
        "email": { "type": "string", "format": "email", "description": "Email address of the student" },
        "graduationMedia": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["image", "video", "audio"] },
              "url": { "type": "string" },
              "name": { "type": "string" },
              "uploadedAt": { "type": "string", "format": "date-time" }
            }
          },
          "description": "Media files related to student graduation"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created" },
        "createdBy": { "type": "string", "description": "UID of the admin who added the student" }
      },
      "required": ["name", "createdAt", "createdBy"]
    },
    "Tracking": {
      "title": "Tracking",
      "description": "Daily tracking record for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Reference to the student ID" },
        "date": { "type": "string", "format": "date", "description": "Date of tracking (YYYY-MM-DD)" },
        "status": { "type": "string", "enum": ["In Rwanda", "Traveled"], "description": "Tracking status" },
        "markedAt": { "type": "string", "format": "date-time", "description": "When the tracking was marked" },
        "markedBy": { "type": "string", "description": "UID of the admin who marked it" }
      },
      "required": ["studentId", "date", "status", "markedAt", "markedBy"]
    },
    "User": {
      "title": "User",
      "description": "Admin user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin"], "description": "User role" },
        "name": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Leadership": {
      "title": "Leadership",
      "description": "Former and current leaders of the association",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "position": { "type": "string", "enum": ["President", "Deputy President", "Speaker", "Deputy Speaker", "Secretary General", "Treasurer"] },
        "term": { "type": "string", "description": "e.g., 2023-2024" },
        "status": { "type": "string", "enum": ["Current", "Former"] },
        "photoUrl": { "type": "string" },
        "bio": { "type": "string" }
      },
      "required": ["name", "position", "term", "status"]
    },
    "GovernanceDocument": {
      "title": "Governance Document",
      "description": "Official documents like Constitutions and Election Manuals",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Constitution", "Election Manual"] },
        "fileUrl": { "type": "string" },
        "version": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "fileUrl", "updatedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user or a general announcement",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Target user UID (null for announcements)" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["announcement", "status_update", "system"] },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "createdAt"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of students"
    },
    "/tracking/{trackingId}": {
      "schema": "Tracking",
      "description": "Collection of tracking records"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin user profiles"
    },
    "/leadership/{leaderId}": {
      "schema": "Leadership",
      "description": "Collection of leaders"
    },
    "/governance/{docId}": {
      "schema": "GovernanceDocument",
      "description": "Official governance documents"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of notifications"
    }
  }
}
